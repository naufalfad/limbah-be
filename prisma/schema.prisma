datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN_DLH
  PETUGAS_LAPANGAN
  PERUSAHAAN
  PENGANGKUT
  AUDITOR
}

enum CompanyStatus {
  PENDING
  REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum DocType {
  SPPL
  UKL_UPL @map("UKL-UPL")
  AMDAL
}

enum WasteLogStatus {
  Terverifikasi
  Proses_Verifikasi @map("Proses Verifikasi")
  Terjadwal_Pickup @map("Terjadwal Pickup")
  Ditolak
}

enum PickupStatus {
  PENDING
  PRICED
  PAID
  ON_THE_ROAD
  LOADED
  COMPLETED
}

enum InvoiceType {
  Pengangkutan
  Retribusi_SPPL @map("Retribusi SPPL")
  Retribusi_UKL_UPL @map("Retribusi UKL-UPL")
  Denda
}

enum InvoiceStatus {
  UNPAID
  ESCROW
  SETTLED
  REFUNDED
}

enum InspectionStatus {
  Selesai
  Terjadwal
  Dibatalkan
}

enum NotificationType {
  WARNING
  INFO
  SUCCESS
  DANGER
}

// Enum untuk State Machine Pelaporan Publik
enum ReportStatus {
  PENDING           // Menunggu kurasi Admin DLH
  VERIFIED          // Valid, siap diubah jadi Surat Tugas Inspeksi
  INVESTIGATING     // Sedang di-BAP oleh Petugas Lapangan
  RESOLVED          // Kasus ditutup / Selesai ditindak
  REJECTED          // Spam / Hoax / Data tidak valid
}

// Enum Sumber Data Telemetri Air (Adapter Pattern)
enum SourceType {
  SIMULATED
  PHYSICAL_IOT
}

// Enum Status Operasional Perangkat Sensor Fisik
enum StationStatus {
  ACTIVE
  MAINTENANCE
  OFFLINE
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password      String
  role          UserRole
  companyId     String?   // Keep for fallback compatibility
  transporterId String?   // ID Pengangkut (opsional jika PENGANGKUT)
  officerId     String?   // ID Petugas Lapangan (opsional jika PETUGAS_LAPANGAN)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  companies     Company[] @relation("UserCompanies")
}

model Company {
  id               String        @id @default(uuid())
  companyName      String
  nib              String        @unique
  npwp             String
  picName          String
  picPhone         String
  picRole          String
  investmentType   String        // PMDN / PMA
  yearBuilt        String
  buildingArea     Float
  operationalHours String
  rawMaterials     String
  waterSource      String
  powerSource      String
  kbli             String
  investment       Float
  landArea         Float
  employees        Int
  lat              String
  lng              String
  address          String
  docType          DocType
  status           CompanyStatus @default(PENDING)
  score            Float?        // ESG Score kepatuhan (0 - 100)
  wasteInfo        String?
  hasTps           Boolean       @default(false)
  docNibUrl        String?       // Path/URL file scan NIB
  docNpwpUrl       String?       // Path/URL file scan NPWP
  docSiteplanUrl   String?       // Path/URL file Siteplan Layout (opsional)
  docTemplateUrl   String?       // Path/URL file completed matrix template (UKL-UPL / SPPL)
  parsedTemplateData Json?       // Menyimpan hasil parse Excel terstruktur
  certificateActiveUntil String? // Masa berlaku izin (YYYY-MM-DD)
  
  // AMDAL specific fields
  activityName           String?
  envApprovalNo          String?
  envApprovalDate        String?
  amdalNo                String?
  amdalYear              String?
  businessSector         String?
  
  // AMDAL files
  docAndalUrl            String?
  docRklUrl              String?
  docRplUrl              String?
  docSkKelayakanUrl      String?
  docPersetujuanUrl      String?
  
  // AMDAL parsed data
  parsedRklData          Json?
  parsedRplData          Json?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  picId            String?
  pic              User?         @relation("UserCompanies", fields: [picId], references: [id], onDelete: Cascade)

  wasteLogs        WasteLog[]
  pickupRequests   PickupRequest[]
  invoices         Invoice[]
  inspections      Inspection[]
}

model WasteLog {
  id          String         @id @default(uuid())
  companyId   String
  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type        String         // Contoh: Oli Bekas, Limbah Cair Kimia, dll
  volume      Float
  unit        String         // L / kg / m³
  date        String         // Format: YYYY-MM-DD
  method      String         // Dinas / Mandiri
  status      WasteLogStatus
  note        String?
  createdAt   DateTime       @default(now())
}

model PickupRequest {
  id              String       @id @default(uuid())
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  wasteType       String
  volume          String       // Contoh: "45 L"
  date            String       // Format: YYYY-MM-DD
  status          PickupStatus @default(PENDING) // FIX: Sintaksis tipe enum dibersihkan dari React braces
  transporterId   String?      // Contoh: "TRANS-001"
  transporterName String?
  cost            Float?       // Biaya pengangkutan (setelah dihitung otomatis atau diisi Admin DLH)
  plateNo         String?
  driverName      String?
  evidencePhoto   String?
  invoiceId       String?
  address         String?
  actualVolume    String?      // Laporan volume akhir dari transporter
  transportReport String?      // Catatan laporan dari transporter
  createdAt       DateTime     @default(now())
}

model Invoice {
  id          String        @id @default(uuid())
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type        InvoiceType
  amount      Float
  date        String        // Format: YYYY-MM-DD
  status      InvoiceStatus @default(UNPAID)
  createdAt   DateTime      @default(now())
}

model Inspection {
  id             String           @id @default(uuid())
  companyId      String
  
  // PERUBAHAN ARSITEKTURAL: Menggunakan onDelete: Restrict untuk mencegah
  // penghapusan data perusahaan secara tidak sengaja apabila memiliki riwayat inspeksi aktif.
  company        Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  
  inspectorId    String
  inspectorName  String
  date           String           // Format: YYYY-MM-DD
  score          Float?           // Nilai hasil inspeksi (0-100)
  status         InspectionStatus @default(Terjadwal)
  location       String
  notes          String?
  photo          String?
  bapSigned      Boolean          @default(false)
  
  // Checklist item disimpan sebagai objek JSON
  checklist      Json?            // Format: { tpsB3: boolean, ipal: boolean, apar: boolean, noise: boolean, safetyEquipment: boolean }
  
  // RELASI BALIK KE CITIZEN REPORT DIHAPUS UNTUK MENJAGA ISOLASI CORE SYSTEM

  createdAt      DateTime         @default(now())
}

// Entitas Utama Laporan Spasial Masyarakat (Isolasi Mandiri / Arsip Statis)
model CitizenReport {
  id              String       @id @default(uuid())
  
  // ID unik dan pendek untuk diberikan ke warga sebagai akses pelacakan
  trackingId      String       @unique
  
  // Identitas opsional untuk whistleblower
  reporterName    String?      
  reporterContact String?      
  
  // Payload
  incidentType    String       
  description     String       @db.Text
  lat             String
  lng             String
  
  // IMPLEMENTASI PILIHAN B (Multipart Multer Upload):
  // Field ini menyimpan serialized JSON array string dari path file foto di server.
  evidencePhoto   String       @db.Text
  
  // State Workflow & Evaluasi
  status          ReportStatus @default(PENDING)
  adminNotes      String?      
  
  // RELASI MAUPUN ID HUBUNGAN DENGAN INSPECTION DIHAPUS TOTAL DI SINI

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model SystemNotification {
  id        String           @id @default(uuid())
  title     String
  message   String
  type      NotificationType
  timestamp DateTime         @default(now())
  read      Boolean          @default(false)
}

model AuditLog {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())
  user      String
  role      String
  action    String
}

// ============================================================================
// MODEL BARU: AQI CACHE SERVER (Information Expert & Protected Variations)
// Menyimpan data telemetri kualitas udara dan cuaca historis dari stasiun klaster.
// ============================================================================
model AqiCache {
  id        String   @id @default(uuid())
  clusterId String   @unique // Contoh: 'cluster-citeureup'
  name      String
  lat       String
  lng       String
  aqi       Int
  weather   Json     // Menyimpan parameter cuaca (suhu, kelembapan, angin, tekanan)
  source    String   // 'live' | 'simulation'
  updatedAt DateTime @updatedAt
}

// ============================================================================
// [MODEL BARU] STASIUN PEMANTAUAN KUALITAS AIR SUNGAI (WaterStation_PT)
// ============================================================================
model WaterStation {
  id            String             @id // Kita gunakan ID manual (WS-01, WS-02) agar sinkron dengan FE
  name          String
  lat           String             // Disamakan bertipe String sesuai koordinat Company
  lng           String
  sourceType    SourceType         @default(SIMULATED)
  status        StationStatus      @default(ACTIVE)
  deviceId      String?            @unique // Untuk kebutuhan integrasi fisik hardware IoT kelak
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  
  telemetryLogs WaterTelemetryLog[]
}

model WaterTelemetryLog {
  id            String             @id @default(uuid())
  stationId     String
  station       WaterStation       @relation(fields: [stationId], references: [id], onDelete: Cascade)
  month         String             // Jan, Feb, Mar, dsb.
  bod           Float              // mg/L (BOD5 standar)
  cod           Float              // mg/L
  do            Float              // mg/L (Dissolved Oxygen)
  ph            Float              // Derajat Keasaman
  createdAt     DateTime           @default(now())
}